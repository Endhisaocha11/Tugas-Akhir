rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function myUid() {
      return request.auth.uid;
    }

    // Cross-document read — dipakai untuk cek role.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(myUid())).data.role;
    }

    function isSuperAdmin() {
      return isSignedIn() && getUserRole() == 'SUPER_ADMIN';
    }

    // ── users/ ───────────────────────────────────────────────────────────────
    //
    // allow list: if isSignedIn() — USER perlu bisa query daftar admin
    // untuk MonitoringSelection (query where role == SUPER_ADMIN).

    match /users/{uid} {
      allow get:  if isSignedIn();
      allow list: if isSignedIn();

      // Buat profil sendiri saat pertama sign-in
      allow create: if isSignedIn() && myUid() == uid;

      // Update terbatas pada field yang aman
      allow update: if isSignedIn() && myUid() == uid &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly([
                          'onboardingCompleted',
                          'claimedDeviceId',
                          'email',
                          'monitoringAdminId',
                          'monitoringAdminEmail',
                        ]);
    }

    // ── cats/ ────────────────────────────────────────────────────────────────

    match /cats/{catId} {
      allow read:   if isSignedIn();
      allow create: if isSuperAdmin() && request.resource.data.ownerId == myUid();
      allow update: if isSuperAdmin() && resource.data.ownerId == myUid();
      allow delete: if isSuperAdmin() && resource.data.ownerId == myUid();
    }

    // ── catProfileHistory/ ───────────────────────────────────────────────────

    match /catProfileHistory/{histId} {
      // Hanya SUPER_ADMIN pemilik data (ownerId == uid sendiri) yang boleh baca —
      // mencegah user lain (termasuk akun monitoring/member) membaca riwayat
      // profil kucing milik admin lain lewat query langsung ke Firestore.
      allow read:           if isSuperAdmin() && resource.data.ownerId == myUid();
      allow create:         if isSuperAdmin() && request.resource.data.ownerId == myUid();
      allow update, delete: if isSuperAdmin() && resource.data.ownerId == myUid();
    }

    // ── feedingLogs/ ─────────────────────────────────────────────────────────

    match /feedingLogs/{logId} {
      allow read:           if isSignedIn();
      allow create:         if isSuperAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // ── devices/ ─────────────────────────────────────────────────────────────

    match /devices/{deviceId} {
      allow read: if isSignedIn();

      allow update: if isSuperAdmin() &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['isClaimed', 'claimedBy', 'claimedAt', 'linkedCatId']);

      allow create, delete: if false;
    }
  }
}
