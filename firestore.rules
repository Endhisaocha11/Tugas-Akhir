rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'SUPER_ADMIN';
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile Rules
    match /users/{uid} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role', 'onboardingCompleted', 'createdAt']) &&
               data.keys().size() == 5 &&
               data.uid is string &&
               data.email is string &&
               data.role in ['SUPER_ADMIN', 'USER'] &&
               data.onboardingCompleted is bool &&
               data.createdAt is number;
      }

      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['onboardingCompleted', 'email']) &&
                      isValidUser(request.resource.data);
    }

    // Cat Profile Rules
    match /cats/{catId} {
      function isValidCat(data) {
        return data.keys().hasAll(['id', 'ownerId', 'name', 'gender', 'weight', 'dailyCalorieTarget', 'dailyGramTarget']) &&
               data.ownerId == request.auth.uid &&
               data.weight is number && data.weight > 0;
      }

      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidCat(request.resource.data);
      allow update: if (isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid)) && 
                      isValidCat(request.resource.data);
      allow delete: if isAdmin();
    }

    // Feeding Log Rules
    match /cats/{catId}/logs/{logId} {
      allow read: if isSignedIn() && (get(/databases/$(database)/documents/cats/$(catId)).data.ownerId == request.auth.uid || isAdmin());
      allow create: if isAdmin(); // Only system/admin can log feeding for now, or maybe system
      allow update, delete: if isAdmin();
    }

    // Device Status Rules
    match /devices/{deviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
