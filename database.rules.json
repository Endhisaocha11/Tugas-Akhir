{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true",
        ".write": "auth.uid === $uid",
        "feedingCommands": {
          ".read": "auth.uid === $uid",
          ".write": "auth.uid === $uid",
          "$command": {
            ".validate": "newData.hasChildren(['amount', 'timestamp', 'type', 'status'])"
          }
        },
        "feedingHistory": {
          ".read": "auth.uid === $uid",
          ".write": false
        },
        "deviceStatus": {
          ".read": "auth.uid === $uid",
          ".write": false
        },
        "schedule": {
          ".read": "auth.uid === $uid",
          ".write": "auth.uid === $uid"
        }
      }
    },
    "devices": {
      "$deviceId": {
        ".read": "auth != null",
        ".write": false
      }
    }
  }
}
